# Koza / build artifacts (regenerated by `just transform` / `just release`)
output/
.koza.generated.yaml

# --- Committed caches (dismech pattern) ---
# Small, derived, deterministic caches ARE committed so CI is fast, offline, and reproducible:
#   cache/                 term + enum (reachable_from) validation caches  -> no NCIT/MONDO sqlite in CI
#   data/node_details.json canonical node enrichment (NodeNorm + OAK)
#   references_cache/       fetched PMID/PMC reference text (when PMIDs are added)
# Ignore only locks and large/secret caches.
cache/**/*.lock
cache/embeddings/
data/*
!data/node_details.json

# Generated schema artifacts
src/fda_biologics/datamodel.py
docs/schema/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
